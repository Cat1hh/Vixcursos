# URL publica do projeto no Vercel
PUBLIC_BASE_URL=https://seu-projeto.vercel.app

# Banco MySQL
DB_HOST=seu-host-mysql
DB_PORT=3306
DB_USER=seu-usuario-mysql
DB_PASSWORD=sua-senha-mysql
DB_NAME=seu-banco-mysql
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_CONNECT_TIMEOUT=6000
DB_QUERY_TIMEOUT=7000
DB_WAIT_FOR_CONNECTIONS=true
DB_CONNECTION_LIMIT=10

# Porta local (Vercel injeta PORT automaticamente)
PORT=3000

# Admin
ADMIN_JWT_SECRET=troque-este-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# SMTP (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=seu-email
EMAIL_PASS=sua-senha-app
EMAIL_FROM="Vix Cursos <seu-email>"

# Twilio / WhatsApp (opcional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_CONTENT_SID=
TWILIO_CONTENT_VARIABLES=
TWILIO_TO_NUMBER=
TWILIO_CHANNEL=sms
WHATSAPP_PROVIDER=twilio
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
